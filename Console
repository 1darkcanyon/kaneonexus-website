(function() {
  const canvas = document.getElementById('cosmos');
  const ctx = canvas.getContext('2d');
  let stars = [];
  function resize() {
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;
    stars = Array.from({ length: 160 }, () => ({
      x: Math.random() * canvas.width, y: Math.random() * canvas.height,
      r: Math.random() * 1.2 + 0.1, a: Math.random() * Math.PI * 2,
      speed: Math.random() * 0.003 + 0.001,
      color: Math.random() > 0.85 ? 'rgba(245,158,11,' : Math.random() > 0.6 ? 'rgba(224,64,251,' : 'rgba(0,229,255,',
    }));
  }
  function draw() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    stars.forEach(s => {
      s.a += s.speed;
      const alpha = 0.08 + Math.sin(s.a) * 0.2;
      ctx.beginPath(); ctx.arc(s.x, s.y, s.r, 0, Math.PI * 2);
      ctx.fillStyle = s.color + Math.max(0, alpha) + ')'; ctx.fill();
    });
    requestAnimationFrame(draw);
  }
  window.addEventListener('resize', resize); resize(); draw();
})();

