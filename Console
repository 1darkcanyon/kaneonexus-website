function getMoonData() {
  const now = new Date();
  const ref = new Date('2000-01-06T18:14:00Z');
  const diff = (now - ref) / 86400000;
  const cycle = 29.53058867;
  const phase = ((diff % cycle) + cycle) % cycle;
  const pct = phase / cycle;
  const phases = [
    { name: 'NEW MOON',        glyph: '🌑', tide: 'Deep rest. Seeds of intention.',    min: 0,     max: 0.037 },
    { name: 'WAXING CRESCENT', glyph: '🌒', tide: 'Intention awakens. Begin.',         min: 0.037, max: 0.25  },
    { name: 'FIRST QUARTER',   glyph: '🌓', tide: 'Action energy. Overcome.',          min: 0.25,  max: 0.463 },
    { name: 'WAXING GIBBOUS',  glyph: '🌔', tide: 'Refinement. Almost full.',          min: 0.463, max: 0.5   },
    { name: 'FULL MOON',       glyph: '🌕', tide: 'Peak illumination. Release.',       min: 0.5,   max: 0.537 },
    { name: 'WANING GIBBOUS',  glyph: '🌖', tide: 'Gratitude. Share the harvest.',     min: 0.537, max: 0.75  },
    { name: 'LAST QUARTER',    glyph: '🌗', tide: 'Let go. Surrender what served.',    min: 0.75,  max: 0.963 },
    { name: 'WANING CRESCENT', glyph: '🌘', tide: 'Rest. Prepare for new cycle.',      min: 0.963, max: 1.0   },
  ];
  const p = phases.find(p => pct >= p.min && pct < p.max) || phases[0];
  const illum = Math.round(pct <= 0.5 ? pct * 200 : (1 - pct) * 200);
  return { ...p, pct, illum };
}

